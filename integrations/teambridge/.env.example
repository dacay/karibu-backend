PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Postgres connection string. Same instance as apps/backend in dev/prod;
# tables live in the `integrations` schema (see DEVELOPMENT.md → Data layer).
DATABASE_URL=postgres://user:password@localhost:5432/karibu

# Teambridge OAuth (Auth0 client credentials)
TEAMBRIDGE_CLIENT_ID=
TEAMBRIDGE_CLIENT_SECRET=
TEAMBRIDGE_AUDIENCE=https://api.teambridge.com/openapi/
TEAMBRIDGE_TOKEN_URL=https://teambridge.us.auth0.com/oauth/token

# Teambridge Open API base
TEAMBRIDGE_API_BASE=https://open-api.teambridge.com

# Teambridge "web" API — used for task templates (POST /tasks/template), which
# the unified Open API does not support. Static bearer token, no OAuth exchange.
TEAMBRIDGE_WEB_TOKEN=
TEAMBRIDGE_WEB_API_BASE=https://api.teambridge.com

# Webhook HMAC secret (shown once when subscription is created)
TEAMBRIDGE_WEBHOOK_SECRET=

# Set to "false" to bypass HMAC signature verification on incoming webhooks.
# Use only for debugging — never in production.
VERIFY_WEBHOOK_SIGNATURE=true

# Comma-separated Teambridge role names eligible for Karibu onboarding. Only shift
# assignees whose user record has at least one of these roles will be invited and
# given a verification task. Empty/unset disables the filter (everyone gets onboarded;
# logs a warn at boot — set this in prod).
# Example: TEAMBRIDGE_ELIGIBLE_ROLES=RN,LPN,CNA
TEAMBRIDGE_ELIGIBLE_ROLES=

# How many days to keep rows in `integrations.teambridge_events` (the dedup/audit
# table). Periodic cleanup runs hourly. 0 disables cleanup. Default 30.
TEAMBRIDGE_EVENT_RETENTION_DAYS=30

# Per-tenant facility mapping file (Teambridge location UUIDs are per-tenant).
# Use facilities.sandbox.json for sandbox, facilities.prod.json for prod.
FACILITIES_FILE=facilities.sandbox.json

# Per-Karibu-org API keys.
# Each entry in facilities.*.json references an env var by name via `karibu_api_key_env`.
# Define those env vars here, one per Karibu org you route to. Missing vars throw at boot.
# Example (matches the sandbox facility map):
KARIBU_NURSING_HOME_API_KEY=

# Optional shared bearer for the inbound Karibu → integration webhook
# (POST /webhooks/karibu/ml-completed). If unset the endpoint accepts any
# request — fine for PoC, set to a real secret in prod.
KARIBU_WEBHOOK_BEARER=
